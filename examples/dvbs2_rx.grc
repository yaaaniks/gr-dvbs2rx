- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      import random\nimport collections\nimport struct\nimport itertools\nimport enum\
      \ \nimport ctypes\n\nfrom itertools import cycle, islice\nfrom gnuradio import\
      \ gr\n\nimport pmt\n\nclass UPID(enum.Enum):\n    TLM = np.byte(0x40)\n    DUMMY\
      \ = np.byte(0x20)\n    \nSYM_RATE = 1000000 # mb used for tlm rate check\nSTRICT_CHUNK_SIZE\
      \ = 4096\nFRAME_SIZE = 188\nSYNC = 0x47\nDUMMY_BYTE = np.byte(0xAA)\n\ndef consume(iterator,\
      \ n):\n    \"Advance the iterator n-steps ahead. If n is none, consume entirely.\"\
      \n    if n is None:\n        collections.deque(iterator, maxlen=0)\n    else:\n\
      \        next(islice(iterator, n, n), None)\n\nclass blk(gr.sync_block):  #\
      \ other base classes are basic_block, decim_block, interp_block\n    \"\"\"\
      Embedded Python Block example - a simple multiply const\"\"\"\n\n    def __init__(self,\
      \ fer_count=1000):  # only default arguments here\n        \"\"\"arguments to\
      \ this function show up as parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n\
      \            self,\n            name='FER',   # will show up in GRC\n      \
      \      in_sig=[np.byte],\n            out_sig=[np.float32]\n        )\n    \
      \    self.message_port_register_out(pmt.intern('fer_counter'))\n        # if\
      \ an attribute with the same name as a parameter is found,\n        # a callback\
      \ is registered (properties work, too).\n        self.measurements = fer_count\n\
      \        \n        self.fer: float = 0\n        self.byte_err_cnt = 0\n    \
      \    self.frame_count = 0\n        self.fer_cnt = 0\n        self.i_fer_cnt\
      \ = 0\n        self.least_dummy_cnt = 0\n        self.most_dummy_cnt = 0\n \
      \       self.tlm_cnt = 0\n        self.prev_frame_bytes = []\n    \n    def\
      \ sync_find(self, chunk: np.ndarray) -> list:\n        frames = []\n       \
      \ if len(self.prev_frame_bytes):\n            lost = FRAME_SIZE - self.prev_frame_bytes.size\n\
      \            prev_frame = np.append(self.prev_frame_bytes, chunk[:lost])\n \
      \           frames.append(prev_frame)\n            self.prev_frame_bytes = []\n\
      \            chunk = chunk[lost:]\n        it = iter(enumerate(chunk))\n   \
      \     temp_err = 0\n        for index, byte in it:\n            if byte != 0x47:\
      \ \n                self.byte_err_cnt += 1\n                temp_err = self.byte_err_cnt\
      \ // FRAME_SIZE \n                continue \n            if chunk.size - index\
      \ < FRAME_SIZE:\n                self.prev_frame_bytes = chunk[index:]\n   \
      \             break\n            \n            frame = chunk[index:index + FRAME_SIZE]\n\
      \            frames.append(frame)    \n            consume(it, FRAME_SIZE -\
      \ 1)\n            self.fer_cnt += temp_err\n            temp_err = 0\n     \
      \       self.byte_err_cnt = 0\n        return frames\n    \n    def check_header(self,\
      \ header: list) -> bool:\n        if header[2] == UPID.TLM.value:\n        \
      \    return False\n        elif header[2] == UPID.DUMMY.value:\n           \
      \ uk_field = header[3] & 0b11110000\n            least_dummy_cnt = int(header[3]\
      \ & 0b00001111)\n            most_dummy_cnt = int.from_bytes(header[4:8].tobytes(),\
      \ 'big', signed=True)\n            \n            b = self.check_least_dummy_counter(least_dummy_cnt)\
      \ & \\\n                self.check_most_dummy_counter(most_dummy_cnt) & \\\n\
      \                uk_field.bit_count() == 1\n                \n            self.least_dummy_cnt\
      \ = least_dummy_cnt\n            self.most_dummy_cnt = most_dummy_cnt\n    \
      \        return b\n        else:\n            return False\n        \n    def\
      \ check_correctness(self, frame: np.ndarray) -> None:\n        if self.frame_count\
      \ >= self.measurements:\n            self.fer = self.fer_cnt / self.measurements\n\
      \            self.fer_cnt = 0\n            self.frame_count = 0\n        \n\
      \        b = self.check_header(frame[:8]) & self.check_payload(frame[8:].tolist())\n\
      \        if not b:\n            self.i_fer_cnt += 1\n            self.fer_cnt\
      \ += 1\n        \n        self.frame_count += 1\n    \n    def check_least_dummy_counter(self,\
      \ cnt: int) -> bool:\n        b = (cnt - self.least_dummy_cnt == -15) or (cnt\
      \ - self.least_dummy_cnt == 1) \n        return b\n    \n    def check_most_dummy_counter(self,\
      \ cnt: int) -> bool:\n        b = (cnt - self.most_dummy_cnt == 1) \n      \
      \  return b\n    \n    def check_payload(self, payload: list, pid: UPID = UPID.DUMMY)\
      \ -> bool:\n        if pid == UPID.DUMMY:\n            for byte in payload:\n\
      \                if byte != DUMMY_BYTE:\n                    return False\n\
      \            return True\n        else:\n            return True\n    \n   \
      \ def work(self, input_items, output_items):\n        frames = self.sync_find(input_items[0])\n\
      \        for index, frame in enumerate(frames):\n            if frame[2] ==\
      \ UPID.TLM.value:\n                continue\n            self.check_correctness(frame)\n\
      \        output_items[0][:] = self.fer * 100\n        self.message_port_pub(pmt.intern('fer_counter'),\
      \ pmt.intern(f'{self.i_fer_cnt}'))\n        return len(output_items[0])\n  \
      \      \n"
    affinity: ''
    alias: ''
    comment: ''
    fer_count: '1000'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('FER', 'blk', [('fer_count', '1000')], [('0', 'byte', 1)], [('0',
      'float', 1), ('fer_counter', 'message', 1)], 'Embedded Python Block example
      - a simple multiply const', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1616, 848.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      import random\nimport collections\nimport struct\nimport itertools\nimport enum\
      \ \nimport ctypes\nimport pmt\n\nfrom itertools import cycle, islice\nfrom gnuradio\
      \ import gr\n\nfrom itertools import islice, cycle\n\nclass UPID(enum.Enum):\n\
      \    TLM = np.byte(0x40)\n    DUMMY = 0x20\n    \nSYM_RATE = 1000000 # mb used\
      \ for tlm rate check\nSTRICT_CHUNK_SIZE = 4096\nFRAME_SIZE = 188\nSYNC = 0x47\n\
      DUMMY_BYTE_MASK = np.byte(0x55)\n\ntextboxValue = \"\"\n\ndef consume(iterator,\
      \ n):\n    \"Advance the iterator n-steps ahead. If n is none, consume entirely.\"\
      \n    if n is None:\n        collections.deque(iterator, maxlen=0)\n    else:\n\
      \        next(islice(iterator, n, n), None)\n\nclass blk(gr.sync_block):  #\
      \ other base classes are basic_block, decim_block, interp_block\n    \"\"\"\
      Embedded Python Block example - a simple multiply const\"\"\"\n\n    def __init__(self,\
      \ ber_count=1000):  # only default arguments here\n        \"\"\"arguments to\
      \ this function show up as parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n\
      \            self,\n            name='BER',   # will show up in GRC\n      \
      \      in_sig=[np.byte],\n            out_sig=[np.float32]\n        )\n    \
      \    self.message_port_register_out(pmt.intern('ber_counter'))\n        # if\
      \ an attribute with the same name as a parameter is found,\n        # a callback\
      \ is registered (properties work, too).\n        self.measurements = ber_count\n\
      \        self.ber: float = 0\n        self.ber_cnt: int = 0\n        self.i_ber_cnt:\
      \ int = 0\n        self.prev_frame_bytes = []\n        self.frame_count = 0\n\
      \        self.first = True\n        self.least_dummy_cnt = 0\n        self.most_dummy_cnt\
      \ = 0\n        self.tlm_cnt = 0\n        self.counter = cycle([i for i in range(16,\
      \ 32, 1)])\n        \n    def sync_find(self, chunk: np.ndarray) -> list:\n\
      \        frames = []\n        if len(self.prev_frame_bytes):\n            lost\
      \ = FRAME_SIZE - len(self.prev_frame_bytes)\n            prev_frame = np.append(self.prev_frame_bytes,\
      \ chunk[:lost])\n            frames.append(prev_frame)\n            self.prev_frame_bytes\
      \ = []\n            chunk = chunk[lost:]\n        it = iter(enumerate(chunk))\n\
      \        for index, byte in it:\n            if byte != 0x47:\n            \
      \    continue \n            if chunk.size - index < FRAME_SIZE:\n          \
      \      self.prev_frame_bytes = chunk[index:]\n                break\n      \
      \      frame = chunk[index:index + FRAME_SIZE]\n            frames.append(frame)\
      \   \n            consume(it, FRAME_SIZE - 1)\n        \n        return frames\n\
      \    \n    def check_header(self, header: list) -> bool:\n        if header[2]\
      \ == UPID.TLM.value:\n            return False\n        elif header[2] == UPID.DUMMY.value:\n\
      \            uk_field = header[3] & 0b11100000\n            self.ber_cnt +=\
      \ uk_field.bit_count()\n            \n            least_dummy_cnt = int(header[3]\
      \ & 0b00001111)\n            most_dummy_cnt = int.from_bytes(header[4:8].tobytes(),\
      \ 'big', signed=True)\n            \n            b = self.check_least_dummy_counter(least_dummy_cnt)\
      \ & \\\n                self.check_most_dummy_counter(most_dummy_cnt)\n    \
      \            \n            self.least_dummy_cnt = least_dummy_cnt\n        \
      \    self.most_dummy_cnt = most_dummy_cnt\n            return b\n        else:\n\
      \            return False\n    \n    def check_correctness(self, frame: np.ndarray)\
      \ -> None:\n        if self.frame_count > self.measurements:\n            self.frame_count\
      \ = 0\n            self.ber = self.ber_cnt / (self.measurements * FRAME_SIZE\
      \ * 8) \n            #print(f\"Current BER = {self.ber}\")  \n            self.ber_cnt\
      \ = 0\n        \n        b = self.check_header(frame[:8]) & self.check_payload(frame[8:].tolist())\n\
      \n        self.frame_count += 1\n    \n    def check_least_dummy_counter(self,\
      \ cnt: int):\n        flag = (cnt - self.least_dummy_cnt == -15) or (cnt - self.least_dummy_cnt\
      \ == 1)\n        if not flag:\n            self.i_ber_cnt += cnt - self.least_dummy_cnt\
      \  \n            self.ber_cnt += cnt - self.least_dummy_cnt\n        return\
      \ flag\n    \n    def check_most_dummy_counter(self, cnt: int):\n        flag\
      \ = cnt - self.most_dummy_cnt == 1\n        if not flag:\n            self.i_ber_cnt\
      \ += 1\n            self.ber_cnt += 1\n        return flag\n    \n    def check_payload(self,\
      \ payload: list, pid: UPID = UPID.DUMMY):\n        temp_cnt = 0\n        for\
      \ byte in payload:\n            masked = byte & DUMMY_BYTE_MASK\n          \
      \  temp_cnt += masked.bit_count()\n        self.ber_cnt += temp_cnt\n      \
      \  self.i_ber_cnt += temp_cnt \n        return temp_cnt == 0\n    \n    def\
      \ work(self, input_items, output_items):\n        global textboxValue\n    \
      \    frames = self.sync_find(input_items[0])\n        for index, frame in enumerate(frames):\n\
      \            if frame[2] == UPID.TLM.value:\n                continue\n    \
      \        self.check_correctness(frame)\n        output_items[0][:] = self.ber\
      \ * 100\n        self.message_port_pub(pmt.intern('ber_counter'), pmt.intern(f'{self.i_ber_cnt}'))\n\
      \        return len(output_items[0])\n"
    affinity: ''
    alias: ''
    ber_count: '1000'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
